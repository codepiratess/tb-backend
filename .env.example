# App
NODE_ENV=development
PORT=5000
APP_NAME=TownBolt
FRONTEND_URL=http://localhost:3000
MOBILE_APP_SCHEME=townbolt

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DB_HOST=db.[ref].supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=postgres
DB_SSL=true

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Supabase Storage
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=townbolt-media

# Email (Gmail SMTP or SendGrid)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="TownBolt <noreply@townbolt.in>"

# Fast2SMS OTP (activate after DLT 
# registration on fast2sms.com)
# FAST2SMS_API_KEY=get_free_key_at_fast2sms.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# OTP Config
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
